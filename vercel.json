{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server-final-fixed.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server-final-fixed.ts"
    },
    {
      "src": "/(.*)",
      "dest": "server-final-fixed.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
